# Database — PostgreSQL connection string
# Vercel Postgres uses POSTGRES_URL; set DATABASE_URL for local dev
POSTGRES_URL=postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://user:password@host:5432/database

# Payload secret — used for encrypting tokens and hashing
PAYLOAD_SECRET=your-secret-here-change-in-production

# Vercel Blob Storage — for media uploads (assets.transformidable.media)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Base URL for the CMS
NEXT_PUBLIC_SERVER_URL=https://cms.transformidable.media
