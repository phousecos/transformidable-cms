{
  "name": "transformidable-cms",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Payload CMS v3 instance for the Transformidable content ecosystem",
  "scripts": {
    "dev": "next dev",
    "build": "tsx src/migrate.ts && npx payload generate:importmap && next build",
    "migrate": "tsx src/migrate.ts",
    "start": "next start",
    "lint": "next lint",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.14.0",
    "@payloadcms/next": "^3.14.0",
    "@payloadcms/richtext-lexical": "^3.14.0",
    "@payloadcms/storage-vercel-blob": "^3.14.0",
    "graphql": "^16.8.1",
    "next": "15.4.11",
    "payload": "^3.14.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "0.32.6",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.4.11",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": "22.x"
  }
}
